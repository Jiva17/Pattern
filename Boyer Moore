def build_bad_char_table(pattern):
    """
    Build the Bad Character Heuristic table.
    Maps each character → its last occurrence index in the pattern.
    """
    table = {}
    for i, ch in enumerate(pattern):
        table[ch] = i          # Overwrite keeps the rightmost occurrence
    return table


def boyer_moore_search(text, pattern):
    """
    Boyer-Moore Algorithm (Bad Character Heuristic)
    Time Complexity: Best O(n/m), Worst O(nm)
    Space Complexity: O(k) — k = alphabet size

    Searches RIGHT-TO-LEFT within each window, allowing large skips.
    """
    n = len(text)
    m = len(pattern)
    matches = []

    if m == 0 or m > n:
        return matches

    bad_char = build_bad_char_table(pattern)

    s = 0   # s = shift of the pattern w.r.t. the text

    while s <= n - m:
        j = m - 1   # Start matching from the RIGHT end of pattern

        # Move left while characters match
        while j >= 0 and pattern[j] == text[s + j]:
            j -= 1

        if j < 0:                           # Full match found
            matches.append(s)
            # Shift so next character in text aligns with last occurrence in pattern
            if s + m < n:
                s += m - bad_char.get(text[s + m], -1)
            else:
                s += 1
        else:
            # Shift pattern so bad character aligns with its last occurrence
            shift = j - bad_char.get(text[s + j], -1)
            s += max(1, shift)              # Always shift by at least 1

    return matches


# ── Test ──────────────────────────────────────────────
if __name__ == "__main__":
    text    = "AABAACAADAABAABA"
    pattern = "AABA"
    bc_table = build_bad_char_table(pattern)
    result   = boyer_moore_search(text, pattern)

    print(f"Pattern         : '{pattern}'")
    print(f"Bad Char Table  : {bc_table}")
    print(f"Text            : '{text}'")
    print(f"Found at indices: {result}")
