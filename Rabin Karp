if __name__ == "__main__":
    text    = "AABAACAADAABAABA"
    pattern = "AABA"
    result  = rabin_karp_search(text, pattern)
    print(f"Pattern : '{pattern}'")
    print(f"Text    : '{text}'")
    print(f"Found at indices: {result}")
